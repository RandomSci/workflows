    {
      "parameters": {
        "language": "python",
        "pythonCode": "machiavelli_img = \"https://github.com/RandomSci/Personal_Project/raw/main/static/img/Portrait_of_Niccol%C3%B2_Machiavelli_by_Santi_di_Tito.jpg\"\n\n# Define your categories and prompts\nPROMPTS = {\n    \"machiavelli\": (\n        \"Generate a continuous Machiavelli-style story, naturally filling ~25–30 seconds of TTS narration. \"\n        \"Focus on power, ambition, manipulation, betrayal, and strategy. \"\n        \"Include multiple plot beats, philosophical insight, and consequences. \"\n        \"Lines must be sharp, ruthless, thought-provoking, and commanding. \"\n        \"Original content only; do NOT quote historical texts. \"\n        \"Output is for TTS narration only; do NOT include video, cinematic, or image instructions.\"\n    ),\n\n    \"dating\": (\n        \"Generate a sweet, heartwarming, emotional dating narration, naturally filling ~25–30 seconds of TTS narration. \"\n        \"Tone must be gentle, romantic, uplifting, soft, and comforting. \"\n        \"Focus on love, connection, warmth, affection, kindness, and emotional closeness. \"\n        \"Do NOT be aggressive, savage, manipulative, or dark. \"\n        \"Do NOT target men only — keep it universal and gender-neutral. \"\n        \"Original content only; avoid clichés. \"\n        \"For TTS narration only; do NOT include video or camera instructions.\"\n    ),\n\n    \"fitness\": (\n        \"Generate a motivational fitness narration, naturally filling ~25–30 seconds of TTS narration. \"\n        \"Tone: intense, disciplined, determined, tough-love. \"\n        \"Focus on consistency, sacrifice, mental toughness, and growth. \"\n        \"Original content only; no references to influencers. \"\n        \"For TTS narration only; do NOT include video instructions.\"\n    )\n}\n\nfor item in _input.all():\n    category = item.json.get(\"category\", \"dating\").lower()\n\n    # fallback to machiavelli if invalid category\n    video_prompt = PROMPTS.get(category, PROMPTS[\"machiavelli\"])\n\n    item.json.chatInput = video_prompt\n\nreturn _input.all()\n"
      },
