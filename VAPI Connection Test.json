      "parameters": {
        "jsCode": "// Get raw input\nconst items = $input.all();\nconst webhookData = items[0]?.json || items[0] || {};\nconst body = webhookData.body || {};\n\n// Extract conversation messages\nconst messages = body?.message?.artifact?.messages || [];\n\n// Extract call info\nconst call = body?.call || {};\nconst callId = call?.id || 'unknown';\nconst callStatus = call?.status || 'unknown';\n\n// Extract assistant info\nconst assistant = body?.assistant || {};\nconst assistantName = assistant?.name || 'Unknown';\n\n// Build transcript\nlet transcript = 'No conversation data available';\nif (messages.length > 0) {\n  transcript = messages\n    .filter(msg => msg.role === 'user' || msg.role === 'bot')\n    .map(msg => `${msg.role === 'bot' ? 'Agent' : 'Lead'}: ${msg.message || ''}`)\n    .join('\\n');\n}\n\n// Extract tool call arguments\nconst toolCall = body?.message?.toolCalls?.[0]?.function?.arguments || {};\n\n// Normalize lead info\nconst leadData = {\n  first_name: toolCall.firstname || '',\n  last_name: toolCall.lastname || '',\n  email: (toolCall.lead_email || '').replace(/\\s+at\\s+|\\s+dot\\s+/gi, match => match.includes('at') ? '@' : '.').replace(/\\s/g,''),\n  phone: (toolCall.lead_phone || '').replace(/\\D/g, ''),\n  company: toolCall.lead_company || ''\n};\n\n// Determine call outcome\nlet callOutcome = 'completed';\nif (toolCall.disposition === 'not_interested') callOutcome = 'not_interested';\nelse if (toolCall.intent === 'schedule_meeting') callOutcome = 'meeting_scheduled';\nelse if (!leadData.email && !leadData.phone) callOutcome = 'hung_up_early';\n\n// --- Timestamp Handling --- //\n// Use transcript + Date now to compute next Thursday 9AM Philippines time\nconst dateNow = new Date();\nconst timezoneOffset = 8; // Philippines UTC+8\nconst nextThursday = (() => {\n  const dayNow = dateNow.getUTCDay(); // 0=Sun, 4=Thu\n  const targetDay = 4; // Thursday\n  let delta = (targetDay - dayNow + 7) % 7;\n  if (delta === 0 && dateNow.getUTCHours() + timezoneOffset >= 9) delta = 7; // If today is Thursday but time passed\n  const thursday = new Date(dateNow);\n  thursday.setUTCDate(dateNow.getUTCDate() + delta);\n  thursday.setUTCHours(1,0,0,0); // 9AM PHT -> 01:00 UTC\n  return thursday.toISOString().replace(/\\.\\d{3}Z$/, '.000Z');\n})();\n\n// Build action object\nconst action = {\n  type: toolCall.action_type === 'create_calendar_event' || toolCall.intent === 'schedule_meeting' ? 'create_calendar_event' : '',\n  startTime: nextThursday,\n  duration_minutes: toolCall.action_duration_minutes || 30,\n  assigned_to: toolCall.action_assigned_to || 'SDR_1'\n};\n\n// Output JSON\nreturn {\n  chatInput: `Call ID: ${callId}\nCall Status: ${callStatus}\nCall Outcome: ${callOutcome}\nAssistant: ${assistantName}\nDate now: ${dateNow.toISOString()}\n\n=== CONVERSATION TRANSCRIPT ===\n${transcript}\n\n=== EXTRACTED DATA ===\nFirst Name: ${leadData.first_name || 'Not provided'}\nLast Name: ${leadData.last_name || 'Not provided'}\nEmail: ${leadData.email || 'Not provided'}\nPhone: ${leadData.phone || 'Not provided'}\nCompany: ${leadData.company || 'Not provided'}\nIntent: ${toolCall.intent || 'unknown'}\nDisposition: ${toolCall.disposition || 'unknown'}\nAction Type: ${action.type || 'none'}\nStart Time: ${action.startTime}\nDuration: ${action.duration_minutes} minutes\nAssigned To: ${action.assigned_to}\nNotes: ${toolCall.notes || callOutcome}`\n};\n"
      },
