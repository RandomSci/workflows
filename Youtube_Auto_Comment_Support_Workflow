        "language": "python",
        "pythonCode": "my_channel_id = \"UCr2Q0TirO6tHV-ZTEFNzfGQ\"\nunique_comments = {}\n\nfor item in items:\n    data = item[\"json\"]\n    responses = data if isinstance(data, list) else [data]\n\n    for response in responses:\n        for thread in response.get(\"items\", []):\n            # Check if we can reply to this thread\n            thread_snippet = thread.get(\"snippet\", {})\n            can_reply = thread_snippet.get(\"canReply\", True)\n            \n            # Top-level comment\n            top = thread_snippet.get(\"topLevelComment\", {})\n            cid = top.get(\"id\")\n            snippet = top.get(\"snippet\", {})\n            author_id = snippet.get(\"authorChannelId\", {}).get(\"value\")\n            ctext = snippet.get(\"textDisplay\")\n\n            # ✅ Only add if can reply AND not your comment\n            if cid and ctext and author_id != my_channel_id and can_reply:\n                unique_comments[cid] = ctext\n\n            # Replies to comments (these we can also reply to)\n            if can_reply:  # ✅ Check if thread allows replies\n                for reply in thread.get(\"replies\", {}).get(\"comments\", []):\n                    rcid = reply.get(\"id\")\n                    r_snip = reply.get(\"snippet\", {})\n                    rtext = r_snip.get(\"textDisplay\")\n                    r_author_id = r_snip.get(\"authorChannelId\", {}).get(\"value\")\n\n                    if rcid and rtext and r_author_id != my_channel_id:\n                        unique_comments[rcid] = rtext\n\n# Return in n8n format\nreturn [{\"json\": {\"commentId\": cid, \"text\": text}} for cid, text in unique_comments.items()]\n"
      },
