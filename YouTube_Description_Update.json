      "parameters": {
        "language": "python",
        "pythonCode": "import os\n\n# List of AI nodes\nAI_nodes = ['AI Agent - Video Prompter', 'AI Agent - Video Prompter2', 'AI Agent - Video Prompter3']\n\n# File to store counter\ncounter_file = '/tmp/n8n_ai_counter.txt'\n\n# Read or initialize counter\nif os.path.exists(counter_file):\n    with open(counter_file, 'r') as f:\n        current_index = int(f.read().strip())\nelse:\n    current_index = 0\n\n# Assign AI agent\nassigned_ai = AI_nodes[current_index % len(AI_nodes)]\n\n# Increment and save counter for next iteration\nnext_index = (current_index + 1) % len(AI_nodes)\nwith open(counter_file, 'w') as f:\n    f.write(str(next_index))\n\nprint(f\"Iteration: {current_index + 1}, Assigned: {assigned_ai}\")\n\nreturn {\n    'assignedAI': assigned_ai,\n    'chatInput': _json['chatInput'],\n    'videoId': _json['videoId'],\n    'title': _json['snippet']['title'],\n    'description': _json['snippet']['description']\n}"
      },
