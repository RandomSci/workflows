        "pythonCode": "from urllib.parse import urlparse\n\nfor item in _input.all():\n  # Get URL from the 'product' object, not 'aliexpress'\n  url = item.json.get('product', {}).get('url', '')\n  \n  if url and url != 'False':\n    domain = urlparse(url).netloc.lower()\n    is_real_aliexpress = 'aliexpress.com' in domain or 'aliexpress.us' in domain or domain.startswith('aliexpress.')\n  else:\n    domain = ''\n    is_real_aliexpress = False\n  \n  item.json['domain'] = domain\n  item.json['is_real_aliexpress'] = is_real_aliexpress\n\nreturn _input.all()"
