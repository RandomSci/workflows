    {
      "parameters": {
        "language": "python",
        "pythonCode": "import re\nimport json\n\nraw = _input.first().json[\"output\"]\nmatch = re.search(r\"```json\\s*(.*?)\\s*```\", raw, flags=re.S)\nif match:\n    json_text = match.group(1).strip()\nelse:\n    json_match = re.search(r'\\{.*\\}', raw, flags=re.S)\n    if json_match:\n        json_text = json_match.group(0)\n    else:\n        json_text = raw.strip()\n\ntry:\n    parsed = json.loads(json_text)\nexcept json.JSONDecodeError as e:\n    raise ValueError(f\"Invalid JSON: {e}\\nExtracted text: {json_text[:500]}\")\n\nif not isinstance(parsed, dict):\n    raise ValueError(f\"Expected dict, got {type(parsed)}\")\n\n# 2. Check if match was found (NEW FORMAT)\naliexpress_url = parsed.get(\"AliExpress_URL\", \"False\")\nmatch_found = aliexpress_url and aliexpress_url != \"False\"\n\n# 3. Handle NO MATCH scenario\nif not match_found:\n    amazon_data = _('Amazon Dataset Items').first().json\n    return [{\n        \"json\": {\n            \"match_found\": False,\n            \"amazon\": {\n                \"name\": amazon_data.get(\"name\"),\n                \"url\": parsed.get(\"Amazon_URL\", amazon_data.get(\"url\", \"\")),\n                \"asin\": amazon_data.get(\"asin\"),\n                \"price\": amazon_data.get(\"price\", {}).get(\"value\") if isinstance(amazon_data.get(\"price\"), dict) else None,\n                \"currency\": amazon_data.get(\"price\", {}).get(\"currency\", \"USD\") if isinstance(amazon_data.get(\"price\"), dict) else \"USD\"\n            },\n            \"reason\": parsed.get(\"Notes\", \"No matching AliExpress product found\"),\n            \"confidence_level\": parsed.get(\"Confidence_Level\", 0),\n            \"match_type\": parsed.get(\"Match_Type\", \"not_found\"),\n            \"_metadata\": {\n                \"is_match\": False,\n                \"match_confidence\": 0\n            }\n        }\n    }]\n\n# 4. Handle MATCH FOUND scenario\namazon_data = _('Amazon Dataset Items').first().json\n\nresult = {\n    \"match_found\": True,\n    \"aliexpress\": {\n        \"url\": aliexpress_url,\n        \"confidence_level\": parsed.get(\"Confidence_Level\", 0),\n        \"match_type\": parsed.get(\"Match_Type\", \"unknown\"),\n        \"notes\": parsed.get(\"Notes\", \"\")\n    },\n    \"amazon\": {\n        \"name\": amazon_data.get(\"name\"),\n        \"url\": parsed.get(\"Amazon_URL\", amazon_data.get(\"url\", \"\")),\n        \"asin\": amazon_data.get(\"asin\"),\n        \"price\": amazon_data.get(\"price\", {}).get(\"value\") if isinstance(amazon_data.get(\"price\"), dict) else None,\n        \"currency\": amazon_data.get(\"price\", {}).get(\"currency\", \"USD\") if isinstance(amazon_data.get(\"price\"), dict) else \"USD\",\n        \"reviews_count\": amazon_data.get(\"reviewsCount\"),\n        \"stars\": amazon_data.get(\"stars\")\n    },\n    \"_metadata\": {\n        \"validated\": True,\n        \"match_found\": True,\n        \"confidence\": parsed.get(\"Confidence_Level\", 0),\n        \"match_quality\": \"high\" if parsed.get(\"Confidence_Level\", 0) >= 80 else \"medium\" if parsed.get(\"Confidence_Level\", 0) >= 60 else \"low\"\n    }\n}\n\nreturn [{\"json\": result}]"
