    {
      "parameters": {
        "jsCode": "const allInput = $input.all(); \nlet output = [];\n\nallInput.forEach(item => {\n  const products = item.json.items || []; \n  const processedProducts = products.map(product => ({\n    ...product,\n    processed: true\n  }));\n  \n  output.push({\n    json: {\n      ...item.json,\n      items: processedProducts\n    }\n  });\n});\n\nreturn output;"
      },
