    {
      "parameters": {
        "language": "python",
        "pythonCode": "current_item = _input.first().json\n\nAMZ_IMG = current_item.get('thumbnailUrl', '')\nAMZ_URL = current_item.get('url', '')\nAMZ_NAME = current_item.get('name', '')\n\nreturn {\n  \"img\": AMZ_IMG,\n  \"url\": AMZ_URL,\n  \"name\": AMZ_NAME\n}"
