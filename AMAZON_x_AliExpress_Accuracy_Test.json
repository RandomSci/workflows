        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const product = item.json;\n  \n  return {\n    json: {\n      ...product,\n      amazonPrice: product.price?.value || null,\n      amazonCurrency: product.price?.currency || 'USD',\n      amazonUrl: product.url || '',\n      amazonReviews: product.reviewsCount || 0,\n      amazonRating: product.stars || 0\n    }\n  };\n});"
