      "id": "e6b0e544-ee33-4d2d-8cef-64ae7057f07a",
      "name": "AI Agent3",
      "retryOnFail": true
    },
    {
      "parameters": {
        "language": "python",
        "pythonCode": "import re\nimport json\n\nraw = _input.first().json[\"output\"]\nmatch = re.search(r\"```json\\s*(.*?)\\s*```\", raw, flags=re.S)\nif match:\n    json_text = match.group(1).strip()\nelse:\n    json_match = re.search(r'\\{.*\\}', raw, flags=re.S)\n    if json_match:\n        json_text = json_match.group(0)\n    else:\n        json_text = raw.strip()\n\ntry:\n    parsed = json.loads(json_text)\nexcept json.JSONDecodeError as e:\n    raise ValueError(f\"Invalid JSON: {e}\\nExtracted text: {json_text[:500]}\")\n\nif not isinstance(parsed, dict):\n    raise ValueError(f\"Expected dict, got {type(parsed)}\")\n\n# Get product URL and platform\nproduct_url = parsed.get(\"Product_URL\", \"False\")\nplatform = parsed.get(\"Platform\", \"None\")\nmatch_found = product_url and product_url != \"False\"\n\n# Get Amazon data from a node that has the original product info\n# Try to get from 'Comparison Test' or 'Code in JavaScript' node\ntry:\n    amazon_data = _('Comparison Test').first().json\nexcept:\n    try:\n        amazon_data = _('Code in JavaScript').first().json\n    except:\n        # Fallback: get from HTTP Request node\n        amazon_data = _('HTTP Request').first().json\n\n# Handle NO MATCH scenario\nif not match_found:\n    return [{\n        \"json\": {\n            \"match_found\": False,\n            \"amazon\": {\n                \"name\": amazon_data.get(\"name\"),\n                \"url\": amazon_data.get(\"url\", \"\"),\n                \"asin\": amazon_data.get(\"asin\"),\n                \"price\": amazon_data.get(\"price\", {}).get(\"value\") if isinstance(amazon_data.get(\"price\"), dict) else amazon_data.get(\"amazonPrice\"),\n                \"currency\": amazon_data.get(\"price\", {}).get(\"currency\", \"$\") if isinstance(amazon_data.get(\"price\"), dict) else amazon_data.get(\"amazonCurrency\", \"$\")\n            },\n            \"reason\": parsed.get(\"Notes\", \"No matching product found on any platform\"),\n            \"confidence_level\": parsed.get(\"Confidence_Level\", 0),\n            \"match_type\": parsed.get(\"Match_Type\", \"not_found\"),\n            \"platform\": \"None\",\n            \"_metadata\": {\n                \"is_match\": False,\n                \"match_confidence\": 0\n            }\n        }\n    }]\n\n# Handle MATCH found scenario\nresult = {\n    \"match_found\": True,\n    \"product\": {\n        \"url\": product_url,\n        \"platform\": platform,\n        \"confidence_level\": parsed.get(\"Confidence_Level\", 0),\n        \"match_type\": parsed.get(\"Match_Type\", \"unknown\"),\n        \"search_tool_used\": parsed.get(\"Search_Tool_Used\", \"unknown\"),\n        \"notes\": parsed.get(\"Notes\", \"\")\n    },\n    \"amazon\": {\n        \"name\": amazon_data.get(\"name\"),\n        \"url\": amazon_data.get(\"url\", amazon_data.get(\"amazonUrl\", \"\")),\n        \"asin\": amazon_data.get(\"asin\"),\n        \"price\": amazon_data.get(\"price\", {}).get(\"value\") if isinstance(amazon_data.get(\"price\"), dict) else amazon_data.get(\"amazonPrice\"),\n        \"currency\": amazon_data.get(\"price\", {}).get(\"currency\", \"$\") if isinstance(amazon_data.get(\"price\"), dict) else amazon_data.get(\"amazonCurrency\", \"$\"),\n        \"reviews_count\": amazon_data.get(\"reviewsCount\", amazon_data.get(\"amazonReviews\")),\n        \"stars\": amazon_data.get(\"stars\", amazon_data.get(\"amazonRating\"))\n    },\n    \"_metadata\": {\n        \"validated\": True,\n        \"match_found\": True,\n        \"confidence\": parsed.get(\"Confidence_Level\", 0),\n        \"match_quality\": \"high\" if parsed.get(\"Confidence_Level\", 0) >= 80 else \"medium\" if parsed.get(\"Confidence_Level\", 0) >= 60 else \"low\",\n        \"is_aliexpress\": platform.lower() == \"aliexpress\"\n    }\n}\n\nreturn [{\"json\": result}]"
      },
