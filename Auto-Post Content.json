        "jsCode": "let aiOutput = $json[\"output\"];\n\naiOutput = aiOutput.replace(/^```json\\s*|\\s*```$/g, '');\n\nconst parsedOutput = JSON.parse(aiOutput);\n\nconst dataArray = parsedOutput.Data;\n\nconst finalArray = typeof dataArray === 'string' ? JSON.parse(dataArray) : dataArray;\n\nreturn finalArray.map(item => ({ json: item }));\n"
