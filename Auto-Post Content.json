      "parameters": {
        "language": "python",
        "pythonCode": "Youtube_Title = _input.first().json.snippet.title\n\nprompt = f\"\"\"\nYou are connected to a spreadsheet tool. Retrieve all the data related to this YouTube video:\nTitle: {Youtube_Title}\n\nOutput format MUST be exact JSON like this:\n\n{{\n  \"Data\": [\n    {{\n      \"row_number\": 1,\n      \"Date\": \"MM/DD/YYYY\",\n      \"Time\": \"HH:MM\",\n      \"YouTube Title\": \"...\",\n      \"YouTube Description\": \"...\",\n      \"TikTok Description\": \"...\",\n      \"Facebook Reel Description\": \"...\",\n      \"Instagram Description\": \"...\",\n      \"Additional Notes\": {{\n        \"Hashtags\": [...],\n        \"Trends\": [...],\n        \"PostingTips\": [...]\n      }},\n      \"Video Url View\": \"...\",\n      \"Video Url Download\": \"...\",\n      \"col_11\": \"...\"\n    }}\n  ]\n}}\n\nNo extra words, no explanations, no quotes around the outer JSON. Return only valid JSON.\n\"\"\"\n\nreturn {\"chatInput\": prompt}\n"
      },
