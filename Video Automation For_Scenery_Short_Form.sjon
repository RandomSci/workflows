      "name": "Sticky Note1"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Create video prompts.\n\nUser instructions:\n{{ $('Code in Python (Beta)3').item.json.textPrompt }}\n\nDescription of the reference image(s).\n{{ $('Analyze image1').item.json.content }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "=You are an AI agent that generates high-quality cinematic photorealistic scenery prompts. The prompt must describe purely realistic environments. Do not include characters, humans, animals, or any animated/cartoon style elements. Focus on landscapes, natural or urban environments, atmospheric elements, lighting, textures, and cinematic composition. Show the environment immediately in the first frame. Include natural or urban elements such as mountains, forests, rivers, lakes, oceans, deserts, clouds, snow, rain, fog, city streets, rural areas, or architectural structures. Include dynamic environmental details such as moving clouds, falling rain, rippling water, drifting fog, sunlight reflections, blowing leaves, or other atmospheric effects. Describe lighting such as golden hour, sunrise, sunset, overcast, soft diffused light, or moonlight, as appropriate for the scene. Convey a cinematic, dramatic, peaceful, moody, serene, or atmospheric mood. Use realistic color palettes reflecting natural lighting and environment. Include camera perspective such as wide-angle, aerial, drone view, ground-level, or cinematic pan or tracking. Describe all visible environmental elements in detail including terrain, water, sky, vegetation, structures, and textures. Include lighting, shadows, reflections, and atmospheric effects. Avoid narrative, text, quotes, or story elements. Make the scene visually rich, cinematic, and immersive. Use single quotes only and do not include hyphens or dashes. Keywords you may include if appropriate are 'cinematic photorealism', 'realistic lighting', 'atmospheric depth', 'filmic mood', 'natural textures', and 'environment focus'."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 2.2,
