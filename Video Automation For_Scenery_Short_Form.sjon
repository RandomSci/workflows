      "id": "5754a601-21a8-44f6-82f3-4e513c5fd198",
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "language": "python",
        "pythonCode": "import random\nfrom datetime import datetime\n\ndef escape_quotes(s):\n    return s.replace('\"', '\\\\\"')\n\nnow = datetime.now()\n\n# --- Realistic Snow Architecture (Aerial/High-Angle Only) ---\nlocations = [\n    \"aerial view of a snow-buried European castle\",\n    \"high-angle shot of a medieval stone fortress almost completely lost in snow\",\n    \"drone view above a winter Bavarian village barely visible beneath heavy snow layers\",\n    \"top-down shot of a snowy old-town square where most structures are hidden under deep snow\",\n    \"aerial perspective of a cliffside castle covered by near-whiteout snow\",\n    \"wide drone shot of a snowy mountain fortress fading into a blizzard\",\n    \"aerial view of a Scandinavian coastal village nearly erased by thick snowfall\",\n    \"high-altitude view of a frozen lakeside castle engulfed in dense snow\",\n    \"drone capture above an old monastery buried under extreme snow\",\n    \"top-down shot of winding snowy streets nearly indistinguishable under heavy accumulation\",\n    \"aerial view of an Alpine village overwhelmed in deep snow layers\",\n    \"wide drone frame of a medieval town nearly lost in a blizzard\",\n    \"aerial look at a mountain-top fortress swallowed by frosted pines and whiteout snow\",\n    \"high-angle winter shot of an old stone church nearly obscured by heavy white coverage\",\n    \"drone view of a historic riverside castle fading into dense snowfall\"\n]\n\n# --- Weather (WHITEOUT / BLIZZARD ONLY) ---\nweather = [\n    \"extreme heavy snowfall creating near-whiteout visibility\",\n    \"thick blizzard conditions obscuring most structures\",\n    \"intense snowstorm with very low visibility\",\n    \"overwhelming heavy snow covering almost everything\",\n    \"full whiteout with continuous dense snow\",\n    \"blizzard-level snowfall burying architectural details\"\n]\n\n# --- Mood ---\nmoods = [\n    \"silent and overwhelming\",\n    \"harsh winter stillness\",\n    \"dreamlike frozen isolation\",\n    \"cold, consuming, and atmospheric\",\n    \"quiet but brutally snowy\",\n    \"immersive whiteout calm\"\n]\n\n# --- Camera ---\ncamera = [\n    \"drone aerial shot\",\n    \"ultra-wide aerial view\",\n    \"high-angle cinematic aerial frame\",\n    \"top-down drone perspective\",\n    \"sweeping aerial wide shot\",\n    \"static high-altitude drone shot\"\n]\n\n# --- Lighting ---\nlighting = [\n    \"diffused overcast whiteout lighting\",\n    \"cold flat winter illumination with no strong shadows\",\n    \"muted gray-white daylight through snowstorm\",\n    \"soft blizzard-filtered ambient light\",\n    \"low-contrast overcast after heavy snowfall\"\n]\n\n# --- Themes ---\nthemes = [\n    \"Whiteout Castle Aerial Scene\",\n    \"Blizzard Fortress Landscape\",\n    \"Snow-Buried Winter Village\",\n    \"Frozen Architecture in a Snowstorm\",\n    \"Silent Whiteout Castle Vista\",\n    \"Aerial View Lost in Snow\",\n    \"Winter Fortress in Heavy Blizzard\",\n    \"Snow-Consumed European Castle\"\n]\n\n# --- Generate ---\nlocation = random.choice(locations)\nweather_type = random.choice(weather)\nmood = random.choice(moods)\ncamera_type = random.choice(camera)\nlight = random.choice(lighting)\ntheme = random.choice(themes)\n\ngenerated_title = f\"{theme} | {location} with {weather_type}\"\n\ntext_prompt = (\n    f\"Generate an extremely heavy-snow, near-whiteout aerial winter scene of {location} under {weather_type}. \"\n    f\"The environment should be almost obscured, with most details buried in snow. Mood is {mood}. \"\n    f\"Lighting should be {light}. Use a {camera_type}. No people, no animals, no characters. \"\n    f\"Visibility should be low, with dense, overwhelming snowfall, deep snow accumulation, and faded architecture. \"\n    f\"Focus on realism, extreme snow coverage, atmospheric snow depth, and cinematic whiteout conditions.\"\n)\n\nimage_prompt = (\n    f\"Photorealistic near-whiteout aerial shot of {location} with {weather_type}. \"\n    f\"{camera_type}, {light}, heavy dense snow, extreme low visibility, \"\n    \"deep snow accumulation, snow-buried details, atmospheric blizzard depth. \"\n    \"No characters or living beings. Pure environment only.\"\n)\n\ngenerated_title_escaped = escape_quotes(generated_title)\ntext_prompt_escaped = escape_quotes(text_prompt)\nimage_prompt_escaped = escape_quotes(image_prompt)\n\nreturn {\n    \"chatInput\": f\"\"\"\nEnsure to return the output in this EXACT FORMAT:\n{{\n'imagePrompt':'{image_prompt_escaped}',\n'textPrompt':'{text_prompt_escaped}',\n'generatedTitle':'{generated_title_escaped}'\n}}\n\"\"\"\n}\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -3648,
        704
      ],
      "id": "55dc9131-400e-4c4f-8c60-d3386f6888d4",
      "name": "Code in Python (Beta)2"
    },
    {
      "parameters": {
        "language": "python",
        "pythonCode": "import json\nimport re\n\nai_output = _input.first().json.get(\"output\", \"\")\n\n# Extract JSON block\njson_match = re.search(r\"\\{.*\\}\", ai_output, re.DOTALL)\nif not json_match:\n    raise ValueError(\"No JSON found in AI output.\")\njson_str = json_match.group(0)\n\n# Replace single quotes with double quotes (for keys and string values)\njson_str = re.sub(r\"(?<!\\\\)'\", '\"', json_str)\n\n# Remove trailing commas\njson_str = re.sub(r\",(\\s*})\", r\"\\1\", json_str)\njson_str = re.sub(r\",(\\s*\\])\", r\"\\1\", json_str)\n\n# Fallback: sanitize backslashes in strings\ndef sanitize_json_string(s):\n    # Escape unescaped backslashes\n    s = re.sub(r'\\\\(?![\"\\\\/bfnrtu])', r'\\\\\\\\', s)\n    return s\n\njson_str = sanitize_json_string(json_str)\n\n# Attempt to parse JSON\ntry:\n    parsed = json.loads(json_str)\nexcept json.JSONDecodeError as e:\n    # As a last resort: remove problematic backslashes entirely\n    json_str_clean = json_str.replace(\"\\\\\", \"\")\n    try:\n        parsed = json.loads(json_str_clean)\n    except Exception as e2:\n        raise ValueError(f\"Failed to parse JSON even after fallback: {e2}\\nContent: {json_str}\")\n\n# Return clean output\nreturn [{\n    \"json\": {\n        \"imagePrompt\": parsed.get(\"imagePrompt\", \"\"),\n        \"textPrompt\": parsed.get(\"textPrompt\", \"\"),\n        \"generatedTitle\": parsed.get(\"generatedTitle\", \"Untitled\")\n    }\n}]\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
