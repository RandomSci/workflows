        "jsCode": "const now = new Date();\nconst hour = now.getHours();\nconst day = now.getDay();\n\nconst products = [\n  {\n    name: \"Video Generation Workflow\",\n    keyword: \"VIDEO\",\n    description: \"automates YouTube video creation from idea to upload using GPT-4, DALL-E, and n8n\"\n  },\n  {\n    name: \"Content Automation Workflow\",\n    keyword: \"CONTENT\",\n    description: \"AI generates and schedules posts across all platforms 24/7, no human needed\"\n  },\n  {\n    name: \"Comment Automation Workflow\",\n    keyword: \"COMMENTS\",\n    description: \"AI reads and replies to every YouTube comment with contextual on-brand responses\"\n  },\n  {\n    name: \"Affiliate Updates Workflow\",\n    keyword: \"AFFILIATE\",\n    description: \"every night AI rewrites all your video descriptions and refreshes affiliate links automatically\"\n  },\n  {\n    name: \"AI UGC Video Generation Workflow\",\n    keyword: \"UGC\",\n    description: \"generates UGC-style AI videos fully automated, no filming required\"\n  }\n];\n\nconst productCategories = [\n  \"Pain amplifier — describe the manual task so accurately and specifically that it physically hurts to read\",\n  \"Result drop — share a specific outcome your workflow produced while you were asleep, make it feel unreal\",\n  \"Contrast post — show the before manual painful process versus the after automated outcome, night and day\",\n  \"Curiosity hook — tease the system without fully explaining it, make them desperate to ask how\",\n  \"Mistake callout — call out creators still doing this manually and show exactly what it is costing them per week\"\n];\n\nconst viralCategories = [\n  \"Success mindset — talk about what automation actually unlocks: time, money, freedom. Make them feel behind if they are not automating yet. No CTA needed.\",\n  \"Income reality check — hit them with a hard truth about why most solopreneurs stay broke and how automation is the gap. Make them feel it personally. No CTA needed.\",\n  \"2026 vision — make them feel like this year is the year everything changes if they move smart. Automation is the vehicle. Be bold and specific. No CTA needed.\",\n  \"Harsh truth — say the thing nobody else says about working hard manually versus working smart with systems. Short, punchy, slightly uncomfortable. No CTA needed.\",\n  \"Wins post — share a real or realistic milestone that automation made possible. Make the reader feel envy and inspiration at the same time. No CTA needed.\"\n];\n\nconst insightCategories = [\n  \"Tool breakdown — explain how two or three tools (n8n, VAPI, GHL, OpenAI) connect to solve a real business problem. Make it specific enough that a builder respects it and a business owner realizes they need help building it.\",\n  \"Build reveal — describe a specific system you built: what it does, which tools are involved, what problem it solves. No fluff. Make it sound like something a serious engineer built, not a template seller.\",\n  \"Mistake + fix — share a real technical mistake or bad assumption you hit while building an automation system and exactly how you fixed it. Make builders nod and business owners realize this stuff is harder than it looks.\",\n  \"Workflow logic — explain one specific decision inside a real workflow you built: why you chose this approach over another, what would have broken otherwise. Short, specific, shows deep knowledge.\",\n  \"Comparison insight — compare two approaches to solving the same automation problem. Show the tradeoffs. No filler. The reader should learn something they can actually use or think about.\"\n];\n\n// 8 slots per day: 6,9,12,15,17,19,21,23\n// Distribution: 4 product, 2 viral, 2 insight\n// Slot index:      0  1   2   3   4   5   6   7\n// Types:        P  P   V   P   P   V   I   I\nconst hourSlots = [6, 9, 12, 15, 17, 19, 21, 23];\nconst slotIndex = hourSlots.indexOf(hour) !== -1 ? hourSlots.indexOf(hour) : Math.floor(hour / 3) % 8;\n\nconst slotTypes = [\"product\", \"product\", \"viral\", \"product\", \"product\", \"viral\", \"insight\", \"insight\"];\nconst postType = slotTypes[slotIndex];\n\nconst productIndex = (day * 8 + slotIndex) % products.length;\nconst productCategoryIndex = (day + slotIndex) % productCategories.length;\nconst viralCategoryIndex = (day * 3 + slotIndex) % viralCategories.length;\nconst insightCategoryIndex = (day * 2 + slotIndex) % insightCategories.length;\n\nconst selectedProduct = products[productIndex];\nconst selectedProductCategory = productCategories[productCategoryIndex];\nconst selectedViralCategory = viralCategories[viralCategoryIndex];\nconst selectedInsightCategory = insightCategories[insightCategoryIndex];\n\nconst readableDate = now.toLocaleDateString(\"en-US\", {\n  weekday: \"long\",\n  year: \"numeric\",\n  month: \"long\",\n  day: \"numeric\",\n  hour: \"2-digit\",\n  minute: \"2-digit\"\n});\n\nif (postType === \"viral\") {\n  return [{\n    json: {\n      \"Readable date\": readableDate,\n      \"Post type\": \"viral\",\n      \"Selected product\": null,\n      \"Product keyword\": null,\n      \"Product description\": null,\n      \"Post category\": selectedViralCategory,\n      \"Hour\": hour,\n      \"Day of week\": day\n    }\n  }];\n} else if (postType === \"insight\") {\n  return [{\n    json: {\n      \"Readable date\": readableDate,\n      \"Post type\": \"insight\",\n      \"Selected product\": null,\n      \"Product keyword\": null,\n      \"Product description\": null,\n      \"Post category\": selectedInsightCategory,\n      \"Hour\": hour,\n      \"Day of week\": day\n    }\n  }];\n} else {\n  return [{\n    json: {\n      \"Readable date\": readableDate,\n      \"Post type\": \"product\",\n      \"Selected product\": selectedProduct.name,\n      \"Product keyword\": selectedProduct.keyword,\n      \"Product description\": selectedProduct.description,\n      \"Post category\": selectedProductCategory,\n      \"Hour\": hour,\n      \"Day of week\": day\n    }\n  }];\n}"
